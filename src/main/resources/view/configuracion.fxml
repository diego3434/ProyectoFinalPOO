<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.ConfiguracionController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Configuración del Sistema" styleClass="subtitulo"/>
    <Label fx:id="lblConectadoComo"/>

    <TextField fx:id="txtNombreEmpresa" promptText="Nombre de la empresa" maxWidth="320"/>
    <TextField fx:id="txtDireccion" promptText="Dirección" maxWidth="320"/>
    <TextField fx:id="txtTelefono" promptText="Teléfono" maxWidth="320"/>

    <Label text="Logo de la empresa" styleClass="subtitulo"/>
    <HBox spacing="15" alignment="CENTER_LEFT">
        <ImageView fx:id="imgLogoPreview" fitHeight="80" fitWidth="80" preserveRatio="true"/>
        <Button text="Cambiar logo..." onAction="#seleccionarLogo" styleClass="boton-secundario"/>
    </HBox>

    <Button text="Guardar cambios" onAction="#guardarConfiguracion" styleClass="boton-primario"/>
</VBox>
